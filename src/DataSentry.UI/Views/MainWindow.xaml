<Window x:Class="DataSentry.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:DataSentry.UI.Views"
        xmlns:viewModels="clr-namespace:DataSentry.UI.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}"
        Title="DataSentry" Height="700" Width="960" MinHeight="420" MinWidth="720"
        Background="White"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- The two tabs: plain words with an underline on the open one, the way search results pages
             do it. The underline is the whole indicator — no boxes, no borders, no chrome. -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Margin" Value="24,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <StackPanel>
                                <ContentPresenter Margin="0,10,0,8" />
                                <Border x:Name="Underline" Height="3" CornerRadius="1.5" Background="Transparent" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="Open">
                                <Setter TargetName="Underline" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Tag" Value="Open">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- The header: the name, and the two places the app has. Nothing else lives up here. -->
        <Border Grid.Row="0"
                Padding="28,6,28,0"
                BorderBrush="{StaticResource HoverBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="DataSentry"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,4" />

                <Button Content="Search" Command="{Binding ShowSearchCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchTabOpen}" Value="True">
                                    <Setter Property="Tag" Value="Open" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Reports" Command="{Binding ShowReportsCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsReportsTabOpen}" Value="True">
                                    <Setter Property="Tag" Value="Open" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- The open tab. Both views stay alive so switching away from a scan does not lose it. -->
        <Grid Grid.Row="1" Margin="28,24">
            <views:SearchView DataContext="{Binding Search}"
                              Visibility="{Binding DataContext.IsSearchTabOpen,
                                                   RelativeSource={RelativeSource AncestorType=Window},
                                                   Converter={StaticResource VisibleWhenTrue}}" />

            <views:ReportsView DataContext="{Binding Reports}"
                               Visibility="{Binding DataContext.IsReportsTabOpen,
                                                    RelativeSource={RelativeSource AncestorType=Window},
                                                    Converter={StaticResource VisibleWhenTrue}}" />
        </Grid>
    </Grid>
</Window>

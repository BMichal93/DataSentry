<UserControl x:Class="DataSentry.UI.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:DataSentry.UI.Views"
             xmlns:viewModels="clr-namespace:DataSentry.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:SearchViewModel}">

    <!-- The Search tab. Until a scan runs, the screen is one search bar and nothing else — the one
         obvious thing to do. The schedule hides behind the clock; the results appear below the bar
         the moment a scan finishes, the way an answer follows a search. -->

    <Grid MaxWidth="860">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- The search bar: a folder, and Scan. The folder glyph browses; the clock opens the
             schedule; nothing else is on the bar, because nothing else is the task. -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="18,0,6,0"
                    Height="44">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="15"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource HintTextBrush}" />

                    <Grid Grid.Column="1" Margin="12,0,0,0">
                        <TextBox BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 FontSize="14"
                                 Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Choose a folder to scan"
                                   Margin="4,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   FontSize="14"
                                   Foreground="{StaticResource HintTextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FolderPath}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Button Grid.Column="2"
                            Content="&#xE838;"
                            ToolTip="Browse for a folder"
                            Style="{StaticResource IconButton}"
                            Command="{Binding BrowseCommand}" />
                </Grid>
            </Border>

            <Button Grid.Column="1"
                    Content="Scan"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding ScanCommand}" />

            <Button Grid.Column="2"
                    Content="Cancel"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Style="{StaticResource QuietButton}"
                    Command="{Binding CancelCommand}"
                    Visibility="{Binding IsScanning, Converter={StaticResource VisibleWhenTrue}}" />

            <!-- The clock. Blue when a daily scan is set, grey when not — the icon is the status. -->
            <Button Grid.Column="3"
                    Content="&#xE823;"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    ToolTip="Scan on a daily schedule"
                    Command="{Binding ToggleSchedulePanelCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Schedule.HasSchedule}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- The schedule, revealed by the clock and only by the clock. One folder, one hour,
             set or removed in place. Windows fires it, so it runs whether or not the app is open. -->
        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Padding="18,12"
                Background="White"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Visibility="{Binding IsSchedulePanelOpen, Converter={StaticResource VisibleWhenTrue}}">
            <StackPanel>
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding Schedule.HasNoSchedule, Converter={StaticResource VisibleWhenTrue}}">
                    <TextBlock Text="Scan this folder every day at"
                               VerticalAlignment="Center"
                               Style="{StaticResource SecondaryText}" />
                    <TextBox Width="56"
                             Margin="8,0,0,0"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             BorderBrush="{StaticResource HairlineBrush}"
                             Text="{Binding Schedule.StartTimeText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Schedule"
                            Margin="12,0,0,0"
                            Padding="16,6"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ScheduleScanCommand}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding Schedule.HasSchedule, Converter={StaticResource VisibleWhenTrue}}">
                    <TextBlock Text="{Binding Schedule.Description}"
                               VerticalAlignment="Center"
                               Style="{StaticResource SecondaryText}" />
                    <Button Content="Remove"
                            Margin="12,0,0,0"
                            Style="{StaticResource QuietButton}"
                            Command="{Binding Schedule.RemoveCommand}" />
                </StackPanel>

                <TextBlock Text="{Binding Schedule.Message}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource DangerBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Schedule.Message}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <ProgressBar Grid.Row="2"
                     Height="3"
                     Margin="0,16,0,0"
                     IsIndeterminate="True"
                     Foreground="{StaticResource AccentBrush}"
                     BorderThickness="0"
                     Background="Transparent"
                     Visibility="{Binding IsScanning, Converter={StaticResource VisibleWhenTrue}}" />

        <!-- The summary. For most users this is the first thing on screen and the only thing. -->
        <TextBlock Grid.Row="3"
                   Margin="4,22,0,0"
                   FontSize="19"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource TextBrush}"
                   Text="{Binding Status}"
                   Visibility="{Binding HasStatus, Converter={StaticResource VisibleWhenTrue}}" />

        <!-- A footnote, not the headline: nothing here is a decision, only what DataSentry could not see. -->
        <Expander Grid.Row="4"
                  Margin="4,10,0,0"
                  Foreground="{StaticResource SecondaryTextBrush}"
                  Header="{Binding UnreadableFilesSummary}"
                  Visibility="{Binding HasUnreadableFiles, Converter={StaticResource VisibleWhenTrue}}">
            <ItemsControl ItemsSource="{Binding UnreadableFiles}" Margin="24,8,0,0" MaxHeight="120">
                <ItemsControl.Template>
                    <ControlTemplate TargetType="ItemsControl">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </ControlTemplate>
                </ItemsControl.Template>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Margin="0,0,0,3" Style="{StaticResource SecondaryText}">
                            <Run Text="{Binding Reason, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text="—" />
                            <Run Text="{Binding Path, Mode=OneWay}" />
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>

        <!-- The files behind the headline, one quiet line each until clicked. -->
        <views:ResultsView Grid.Row="5"
                           Margin="0,14,0,0"
                           DataContext="{Binding Results}"
                           Visibility="{Binding DataContext.HasFilesToShow,
                                                RelativeSource={RelativeSource AncestorType=views:SearchView},
                                                Converter={StaticResource VisibleWhenTrue}}" />
    </Grid>
</UserControl>

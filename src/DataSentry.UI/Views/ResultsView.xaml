<UserControl x:Class="DataSentry.UI.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:DataSentry.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:ResultsViewModel}">

    <!-- The result list both tabs share: three filter chips, one page of rows, paging links.
         A row is one quiet line until it is clicked; the click opens the detail in place. -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- The one destructive action, on the heading it belongs to. The button says the number,
                 the prompt behind it asks again, and the recycle bin keeps the way back — three
                 chances to stop. -->
            <Button Grid.Column="1"
                    VerticalAlignment="Center"
                    Content="{Binding DeleteButtonText}"
                    Command="{Binding DeleteSuggestedCommand}"
                    Visibility="{Binding CanDelete, Converter={StaticResource VisibleWhenTrue}}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                        <Setter Property="Background" Value="{StaticResource DangerBrush}" />
                        <Setter Property="Padding" Value="16,6" />
                        <Setter Property="FontSize" Value="12" />
                    </Style>
                </Button.Style>
            </Button>

            <!-- Which verdict is on screen. The open chip takes the verdict's own colour, faintly. -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
            <Button Content="{Binding NeedsReviewHeading}" Command="{Binding ShowNeedsReviewCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource FilterChip}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsShowingNeedsReview}" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentTintBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentTintBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="{Binding ToDeleteHeading}" Command="{Binding ShowToDeleteCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource FilterChip}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsShowingToDelete}" Value="True">
                                <Setter Property="Background" Value="#FFFCE8E6" />
                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                <Setter Property="BorderBrush" Value="#FFFCE8E6" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="{Binding ToKeepHeading}" Command="{Binding ShowToKeepCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource FilterChip}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsShowingToKeep}" Value="True">
                                <Setter Property="Background" Value="#FFE6F4EA" />
                                <Setter Property="Foreground" Value="{StaticResource SafeBrush}" />
                                <Setter Property="BorderBrush" Value="#FFE6F4EA" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            </StackPanel>
        </Grid>

        <!-- What the last delete did, and the files it could not take. The same bargain the scan
             strikes with its unreadable files: the count is the finding, the list is the evidence. -->
        <StackPanel Grid.Row="1" Margin="4,10,0,0">
            <TextBlock Text="{Binding DeletionOutcome}"
                       Foreground="{StaticResource TextBrush}"
                       Visibility="{Binding HasDeletionOutcome, Converter={StaticResource VisibleWhenTrue}}" />

            <Expander Margin="0,6,0,0"
                      Header="What could not be deleted, and why"
                      Foreground="{StaticResource SecondaryTextBrush}"
                      Visibility="{Binding HasDeletionFailures, Converter={StaticResource VisibleWhenTrue}}">
                <ItemsControl ItemsSource="{Binding DeletionFailures}" Margin="24,8,0,0" MaxHeight="120">
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,0,3" Style="{StaticResource SecondaryText}">
                                <Run Text="{Binding Reason, Mode=OneWay}" FontWeight="SemiBold" />
                                <Run Text="—" />
                                <Run Text="{Binding FilePath, Mode=OneWay}" />
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>
        </StackPanel>

        <!-- One page of files. Collapsed, a row is a single line: the verdict, the name, the reason,
             the date. Clicking it opens the detail in place — where it lives, what was found in it,
             and why that matters. Progressive disclosure, one row at a time. -->
        <ListBox Grid.Row="2"
                 Margin="0,12,0,0"
                 BorderThickness="0"
                 Background="Transparent"
                 ItemsSource="{Binding Rows}"
                 SelectionMode="Single"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingStackPanel.IsVirtualizing="True">

            <!-- The default ListBoxItem paints selection Windows-blue over the whole row; here the
                 selected row only warms slightly, because selection means "open", not "chosen". -->
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Surface"
                                        Background="Transparent"
                                        BorderBrush="{StaticResource HoverBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,10">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Surface" Property="Background" Value="#FFF8F9FA" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Surface" Property="Background" Value="#FFF8F9FA" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <!-- A row whose file has gone to the bin stays on the page, dimmed:
                                         removing it would misnumber the paging, and the user deserves
                                         to see their decision took. -->
                                    <DataTrigger Binding="{Binding IsRecycled}" Value="True">
                                        <Setter Property="Opacity" Value="0.55" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- The whole row, closed. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Ticked means "delete it with the rest". Only a condemned file gets a
                                 box at all; unticking it is how one file is spared without abandoning
                                 the other eleven. -->
                            <CheckBox Grid.Column="0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding IsSelectedForDeletion}"
                                      IsEnabled="{Binding IsStillOnDisk}"
                                      Visibility="{Binding CanBeDeleted, Converter={StaticResource VisibleWhenTrue}}" />

                            <!-- The verdict as a word, not an icon: "Review" needs no legend. -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding RecommendationText}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SafeBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Recommendation}" Value="Review">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Recommendation}" Value="Delete">
                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding FileName}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="320" />

                            <TextBlock Grid.Column="3"
                                       Text="{Binding Reason}"
                                       Margin="12,0"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Style="{StaticResource SecondaryText}" />

                            <TextBlock Grid.Column="4"
                                       Text="{Binding LastModifiedText}"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource SecondaryText}" />
                        </Grid>

                        <!-- The same row, open. -->
                        <StackPanel x:Name="DetailPanel" Visibility="Collapsed" Margin="108,8,0,2">
                            <TextBlock Text="{Binding FolderPath}"
                                       Style="{StaticResource SecondaryText}"
                                       TextTrimming="CharacterEllipsis" />

                            <!-- Types and counts. The matched value is never shown, here or anywhere:
                                 the report must not become a copy of the data it polices. -->
                            <Border Margin="0,8,0,0"
                                    Padding="8,3"
                                    CornerRadius="4"
                                    Background="{StaticResource AccentTintBrush}"
                                    HorizontalAlignment="Left"
                                    Visibility="{Binding HasPii, Converter={StaticResource VisibleWhenTrue}}">
                                <TextBlock Text="{Binding PiiSummary}" FontSize="12" Foreground="#FF1A4FA8" />
                            </Border>

                            <!-- Why the finding matters — what kind of data and what the exposure is. -->
                            <TextBlock Text="{Binding WhyItMatters}"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource SecondaryText}"
                                       Visibility="{Binding HasPii, Converter={StaticResource VisibleWhenTrue}}" />

                            <!-- The compliant way to see what was found: open the file itself, where
                                 the user's own access controls already guard it. The report never
                                 prints the values — this is the door it points to instead. -->
                            <Button Content="Open file"
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource LinkButton}"
                                    Command="{Binding OpenCommand}"
                                    Visibility="{Binding IsStillOnDisk, Converter={StaticResource VisibleWhenTrue}}" />

                            <TextBlock Text="{Binding OpenProblem}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource DangerBrush}"
                                       Visibility="{Binding HasOpenProblem, Converter={StaticResource VisibleWhenTrue}}" />
                        </StackPanel>
                    </StackPanel>

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                     Value="True">
                            <Setter TargetName="DetailPanel" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="3" Margin="12,10,12,0">
            <TextBlock Text="{Binding PageDescription}"
                       VerticalAlignment="Center"
                       Style="{StaticResource SecondaryText}" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Previous" Style="{StaticResource LinkButton}" Command="{Binding PreviousPageCommand}" />
                <Button Content="Next" Style="{StaticResource LinkButton}" Margin="16,0,0,0" Command="{Binding NextPageCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

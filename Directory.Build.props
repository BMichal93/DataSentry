<Project>

  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <NeutralLanguage>en</NeutralLanguage>
  </PropertyGroup>

  <PropertyGroup>
    <Product>DataSentry</Product>
    <Authors>Michal Budziszewski</Authors>
    <Copyright>Copyright 2026 Michal Budziszewski</Copyright>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>

    <!-- Stamps the assemblies and the published DataSentry.exe. First release for users. -->
    <Version>1.0.0</Version>
  </PropertyGroup>

</Project>
